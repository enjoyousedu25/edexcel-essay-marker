# Required: teacher login passcode (shared)
APP_PASSCODE=change-me

# Optional: OpenAI API key for AI marking & feedback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: allow multiple passcodes (comma-separated). If set, overrides APP_PASSCODE.
APP_PASSCODES=

# Optional: disable OCR (if you only want selectable-text PDFs)
DISABLE_OCR=false

# Optional: maximum upload size in MB
MAX_UPLOAD_MB=15
